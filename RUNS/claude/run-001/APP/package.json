{
  "name": "copilot-metrics-dashboard",
  "private": true,
  "type": "module",
  "workspaces": ["server", "web"],
  "scripts": {
    "dev": "concurrently -n server,web -c blue,green \"npm run dev -w server\" \"npm run dev -w web\"",
    "start": "npm run build -w web && npm start -w server",
    "test": "npm test -w server",
    "lint": "eslint server/",
    "ingest:raw": "npm run ingest:raw -w server",
    "ingest:normalize": "npm run ingest:normalize -w server"
  },
  "devDependencies": {
    "@eslint/js": "^9.21.0",
    "concurrently": "^9.1.0",
    "eslint": "^9.21.0"
  }
}
